{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "target": "es2024",
        "sourceMap": true,
        "esModuleInterop": true,
        "rootDir": "src",
        "outDir": "dist",
        "allowSyntheticDefaultImports": true,
    },
    "typeRoots": ["./node_modules/@utils", "utils"],
     "include": ["src/**/*", "src/models", "utils/**/*", "../env"],
    "exclude": ["node_modules", "dist"]
}